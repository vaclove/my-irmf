DATABASE_URL=postgresql://username:password@localhost:5432/festival_db
PORT=3001
NODE_ENV=development

# Email configuration - Choose one method:

# Method 1: Mailgun API (Recommended)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-domain.com
MAILGUN_FROM_EMAIL=noreply@your-domain.com

# Method 2: Mailgun SMTP (Alternative)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@your-domain.com
SMTP_PASS=your-mailgun-smtp-password

# App configuration
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
SESSION_SECRET=your-session-secret-here

# Google OAuth configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Google Shared Drive (movie files) configuration
# Base64-encoded service-account JSON (preferred), OR a path to the JSON file.
GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/drive-service-account.json
GOOGLE_SHARED_DRIVE_ID=
# Background scan of Drive folders (node-cron). Default every 45 minutes.
MOVIE_SCAN_CRON="*/45 * * * *"
MOVIE_SCAN_ENABLED=true

# Movie preview transcoding. The app enqueues jobs to an Azure Storage Queue;
# an out-of-process worker (Azure Container Apps Job) runs ffmpeg. See
# docs/TRANSCODER_SETUP.md. Leave the connection string blank to disable.
AZURE_STORAGE_CONNECTION_STRING=
TRANSCODE_QUEUE_NAME=movie-transcodes
MOVIE_TRANSCODE_ENABLED=true
# Proxy quality (worker-side; drop HEIGHT to 480 for faster/smaller previews).
MOVIE_TRANSCODE_HEIGHT=720
MOVIE_TRANSCODE_CRF=23
MOVIE_TRANSCODE_PRESET=veryfast

# Daily PostgreSQL backup to Google Drive (production only by default).
# The app enqueues a db_backup message on the transcode queue; the worker runs
# pg_dump and uploads the dump to the shared drive's "Backups" folder, keeping
# the newest DB_BACKUP_RETENTION and permanently deleting older ones.
# DB_BACKUP_ENABLED: leave unset for production-only; 'true' force-enables in
# dev; 'false' disables everywhere.
DB_BACKUP_ENABLED=
DB_BACKUP_CRON="0 3 * * *"
DB_BACKUP_TZ=Europe/Prague
DB_BACKUP_RETENTION=7

# LLM subtitle translation (Anthropic Claude). Jobs run in-process and
# translate movie subtitles between Czech and English. Leave the key blank
# to disable the feature (the UI gets a 503).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Parallel translation jobs in the Express process (keep low: API rate limits).
SUBTITLE_TRANSLATION_MAX_CONCURRENT=1
