# Production Environment Variables for Azure Deployment
# Copy this file and update with your production values

# Application URLs
APP_URL=https://my.irmf.cz
CLIENT_URL=https://my.irmf.cz

# Database Configuration (Azure Database for PostgreSQL with Private Access)
DATABASE_URL=postgresql://festival_admin:your-password@my-irmf.private.postgres.database.azure.com:5432/festival_db?sslmode=require

# Server Configuration
PORT=3001
NODE_ENV=production

# Security
JWT_SECRET=your-production-jwt-secret-change-this
SESSION_SECRET=your-production-session-secret-change-this

# Email Configuration - Mailgun API
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=irmf.cz
MAILGUN_FROM_EMAIL=irmf@irmf.cz

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Authentication Configuration
BYPASS_AUTH_ON_LOCALHOST=false
# Google Shared Drive (movie files) configuration
# Base64-encoded service-account JSON. See docs/GOOGLE_DRIVE_SETUP.md.
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_SHARED_DRIVE_ID=
MOVIE_SCAN_CRON="*/45 * * * *"
MOVIE_SCAN_ENABLED=true
# Movie preview transcoding (Azure Container Apps Job worker). See
# docs/TRANSCODER_SETUP.md. Blank connection string disables enqueueing.
AZURE_STORAGE_CONNECTION_STRING=
TRANSCODE_QUEUE_NAME=movie-transcodes
MOVIE_TRANSCODE_ENABLED=true
MOVIE_TRANSCODE_HEIGHT=720
MOVIE_TRANSCODE_CRF=23
MOVIE_TRANSCODE_PRESET=veryfast

# LLM for subtitle translation + quality gate. Real values live in the
# App Service application settings, not in this template.
# azure = GPT-5.6 Sol (default) | anthropic = Claude Opus fallback
LLM_PROVIDER=azure
AZURE_OPENAI_API_KEY=
